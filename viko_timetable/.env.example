# ──────────────────────────────────────────────────────────────────────
# FRONTEND — copy this to .env and fill in your values
# Set these same variables in Netlify → Site settings → Environment variables
# ──────────────────────────────────────────────────────────────────────

# URL of your backend proxy server (Koyeb / Render / Railway / etc.)
VITE_API_URL=https://your-backend.koyeb.app

# Firebase Realtime Database — get from Firebase console
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
